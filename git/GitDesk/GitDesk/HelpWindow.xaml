<Window x:Class="GitDesk.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyboard Shortcuts — GitDesk" Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}"
        ResizeMode="NoResize">
    
    <Border Padding="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="⌨ Keyboard Shortcuts" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                <!-- General -->
                <TextBlock Text="General" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl + O" FontFamily="Consolas"
                               Foreground="{StaticResource AccentGreenBrush}" Margin="0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Open repository"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="F5" FontFamily="Consolas"
                               Foreground="{StaticResource AccentGreenBrush}" Margin="0,4"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Refresh all"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl + /" FontFamily="Consolas"
                               Foreground="{StaticResource AccentGreenBrush}" Margin="0,4"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Show this help"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Escape" FontFamily="Consolas"
                               Foreground="{StaticResource AccentGreenBrush}" Margin="0,4"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Clear selection / Close dialog"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                </Grid>

                <!-- Git Operations -->
                <TextBlock Text="Git Operations" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBlueBrush}" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl + Enter" FontFamily="Consolas"
                               Foreground="{StaticResource AccentGreenBrush}" Margin="0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Commit changes"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl + Shift + A" FontFamily="Consolas"
                               Foreground="{StaticResource AccentGreenBrush}" Margin="0,4"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Stage all files"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl + Shift + F" FontFamily="Consolas"
                               Foreground="{StaticResource AccentGreenBrush}" Margin="0,4"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Fetch from remote"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl + Shift + P" FontFamily="Consolas"
                               Foreground="{StaticResource AccentGreenBrush}" Margin="0,4"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Pull from remote"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl + Shift + U" FontFamily="Consolas"
                               Foreground="{StaticResource AccentGreenBrush}" Margin="0,4"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Push to remote"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                </Grid>

                <!-- Tips -->
                <TextBlock Text="💡 Power User Tips" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentOrangeBrush}" Margin="0,0,0,10"/>
                <StackPanel Margin="0,0,0,20">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4">
                        • Double-click a branch to check it out instantly
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4">
                        • Right-click files for quick actions (stage, discard, blame)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4">
                        • Right-click commits for cherry-pick, revert, copy SHA
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4">
                        • Use the search box to filter files in real-time
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4">
                        • All network operations show real-time progress
                    </TextBlock>
                </StackPanel>

                <Button Content="Close" Style="{StaticResource AccentButton}"
                        Click="Close_Click" HorizontalAlignment="Center" Padding="30,10"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
